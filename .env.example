# ── GHVAC Tools — local development environment ─────────────────────────────
# Copy to `.env` and fill in values. `.env` is git-ignored.
# The app reads process.env directly; we load this file via `tsx --env-file`.
# Run with:  npm run dev:local   (serves http://localhost:5000)
#
# Everything except DATABASE_URL + SESSION_SECRET is OPTIONAL — the app boots
# without it and just disables that feature. Fill in only what you need.

# ── Core (required) ─────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
# PostgreSQL (Neon serverless). https://neon.tech → project → pooled conn string.
DATABASE_URL=
# Any long random string (session signing). REQUIRED in production — the server
# refuses to start with a default/short secret when NODE_ENV=production.
SESSION_SECRET=
# Admin dashboard password. If unset, admin login (/api/admin/login) is DISABLED
# (there is no hardcoded default). Set a strong value to enable admin access.
ADMIN_PASSWORD=
# Optional shared secret authenticating inbound Textline webhooks. When set, the
# /api/webhooks/textline endpoint requires it as ?secret=... or an
# x-webhook-secret header. Configure the same value in your Textline webhook URL.
TEXTLINE_WEBHOOK_SECRET=
# Legacy API gate. Setting GLOBAL_PASSWORD turns on SERVER-SIDE enforcement for
# the legacy /api routes (quotes, leads, customers, etc.): callers must pass the
# gate password OR be logged in via employee-portal / CRM / admin. Until this is
# set the legacy API stays open (a warning is logged on boot). Force enforcement
# without a shared password by setting ENFORCE_LEGACY_AUTH=true (then access
# requires an employee-portal/CRM/admin login).
GLOBAL_PASSWORD=
# ENFORCE_LEGACY_AUTH=true

# ── OpenAI / AI features (voice, AI quotes, checklist + help AI, search) ─────
# One real key (sk-...) from https://platform.openai.com/api-keys.
# Set BOTH vars to the same key. Leave the BASE_URL vars empty to hit OpenAI.
OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=

# ── Stripe (deposits / invoice payments) ─────────────────────────────────────
# https://dashboard.stripe.com/apikeys  (use TEST keys for local).
STRIPE_KEY=                 # secret key (sk_test_...)
STRIPE_PUBLISHABLE_KEY=     # publishable key (pk_test_...)
# Webhooks: run `stripe listen --forward-to localhost:5000/api/stripe/webhook`
# (Stripe CLI) since localhost isn't publicly reachable. Optional for basic use.

# ── Twilio (SMS magic-link auth + notifications) ─────────────────────────────
# https://console.twilio.com  → Account SID, Auth Token, and an SMS-capable number.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=        # E.164, e.g. +16025551234
# DISABLE_SMS_AUTH=1        # set to skip SMS login entirely in dev

# ── Resend (transactional email: quotes, invoices, e-sign, booking) ──────────
# https://resend.com/api-keys
RESEND_API_KEY=
FROM_EMAIL=                 # verified sender, e.g. noreply@yourdomain.com
SIGNATURE_FROM_EMAIL=       # e-sign sender (defaults to signatures@ghvacinc.com)
MANAGER_EMAIL=              # optional internal notifications recipient
BRAND_NAME=Giesbrecht HVAC
BRAND_COLOR=
# RESEND_WEBHOOK_SECRET=    # only if using inbound email webhook

# ── Google Sheets (pricing, settings, customer sync) ─────────────────────────
# API key: https://console.cloud.google.com → APIs & Services → Credentials
# (enable "Google Sheets API"). Each ID is a different spreadsheet's ID
# (the long token in the sheet URL between /d/ and /edit). Fill the ones you use.
GOOGLE_SHEETS_API_KEY=
GOOGLE_SHEET_ID=            # main pricing/equipment sheet (google-sheets.ts, equipment-sheets.ts)
GOOGLE_SHEETS_ID=           # services/google-sheets.ts (app settings sheet)
PRICEBOOK_SHEETS_ID=        # salesbook package data
FIELDEDGE_CUSTOMER_SHEET_ID= # FieldEdge customer sync sheet

# ── Google OAuth (CRM staff sign-in with Google) ─────────────────────────────
# https://console.cloud.google.com → Credentials → OAuth 2.0 Client (Web).
# Authorized redirect URI must be EXACTLY the value below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5000/api/crm/auth/google/callback

# ── QuickBooks Online (bidirectional sync) ───────────────────────────────────
# https://developer.intuit.com → your app → Keys & OAuth (use Development/sandbox
# keys for local). Register this redirect URI in the Intuit app:
#   http://localhost:5000/api/quickbooks/callback
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
